{
  "name": "claude-flow",
  "version": "0.1.0",
  "description": "Visual workflow manager for Claude Desktop scheduled tasks",
  "type": "module",
  "bin": {
    "claude-flow": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@claude-flow/core": "workspace:*",
    "@claude-flow/server": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "open": "^10.1.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "claude",
    "workflow",
    "scheduled-tasks",
    "automation",
    "claude-desktop",
    "task-manager",
    "react-flow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-flow/claude-flow"
  },
  "license": "MIT"
}

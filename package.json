{
  "name": "claude-flow",
  "version": "0.1.0",
  "description": "Visual workflow manager for Claude Desktop scheduled tasks — n8n-style task orchestration",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @claude-flow/server dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @claude-flow/core test",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "pnpm -r clean"
  },
  "keywords": [
    "claude",
    "workflow",
    "scheduled-tasks",
    "automation",
    "n8n",
    "react-flow"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
